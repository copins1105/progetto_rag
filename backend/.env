# ══════════════════════════════════════════════════════════════
# SELEZIONE PIPELINE
# ══════════════════════════════════════════════════════════════
# Valori possibili:
#   marker  → pipeline originale (Marker locale + Postprocessor + Chunker)
#   mistral → nuova pipeline (Mistral OCR API, zero modelli locali)
#
# Cambia questo valore e riavvia il backend per switchare pipeline.
# I due stack DB sono completamente indipendenti.
INGESTION_PIPELINE="mistral"

# ══════════════════════════════════════════════════════════════
# DATABASE — PIPELINE MARKER (originale, porta 5432 / 8000)
# ══════════════════════════════════════════════════════════════
MARKER_DATABASE_URL="postgresql://admin:POLICYNAVIGATOR@localhost:5432/policy_db"
MARKER_CHROMA_HOST="localhost"
MARKER_CHROMA_PORT="8000"
MARKER_CHROMA_COLLECTION_NAME="documenti_semantici"
MARKER_CHROMA_PATH="http://localhost:8000"

# ══════════════════════════════════════════════════════════════
# DATABASE — PIPELINE MISTRAL (nuova, porta 5433 / 8001)
# ══════════════════════════════════════════════════════════════
MISTRAL_DATABASE_URL="postgresql://admin:POLICYNAVIGATOR@localhost:5433/policy_db"
MISTRAL_CHROMA_HOST="localhost"
MISTRAL_CHROMA_PORT="8001"
MISTRAL_CHROMA_COLLECTION_NAME="documenti_semantici_mistral"
MISTRAL_CHROMA_PATH="http://localhost:8001"

# ══════════════════════════════════════════════════════════════
# ALIAS ATTIVI — usati dal backend (puntano alla pipeline scelta)
# Non modificare: vengono risolti dinamicamente da db_config.py
# ══════════════════════════════════════════════════════════════
# DATABASE_URL, CHROMA_HOST, CHROMA_PORT, CHROMA_COLLECTION_NAME
# vengono impostati a runtime in base a INGESTION_PIPELINE

# ══════════════════════════════════════════════════════════════
# MISTRAL API
