DATABASE_URL="postgresql://admin:POLICYNAVIGATOR@localhost:5432/policy_db"

# ── JWT ──────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="cambia_questa_chiave_con_stringa_casuale_minimo_32_caratteri"
JWT_ALGORITHM="HS256"

# Access token: breve vita per sicurezza
JWT_ACCESS_EXPIRE_MINUTES="15"

# Refresh token: vita lunga, salvato nel DB
JWT_REFRESH_EXPIRE_DAYS="30"

# ── Ambiente ─────────────────────────────────────────────────
# "production" → cookie Secure=True (solo HTTPS)
# "development" → cookie Secure=False (HTTP locale ok)
ENVIRONMENT="development"

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_HOST="localhost"
CHROMA_PORT="8000"
CHROMA_COLLECTION_NAME="documenti_semantici"
CHROMA_PATH=http://localhost:8000

# ── Cartelle ─────────────────────────────────────────────────
STATIC_DIR=C:\Users\PC_A26\Desktop\programmi\TirocinioAI\backend\static
PDF_DIR=C:\Users\PC_A26\Desktop\programmi\TirocinioAI\backend\data
OUTPUT_DIR=C:\Users\PC_A26\Desktop\programmi\TirocinioAI\backend\output_json
CHUNKS_DIR=C:\Users\PC_A26\Desktop\programmi\TirocinioAI\backend\chunks
